{
  "name": "svelte-lightslide",
  "version": "0.1.0",
  "description": "A draggable, accessible image lightbox & gallery for Svelte 5 — a modern rebuild of the Highslide lightbox I loved.",
  "type": "module",
  "author": "Jérôme Soulas (https://portfolio.webzappette.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mate2/svelte-lightslide.git"
  },
  "homepage": "https://github.com/mate2/svelte-lightslide#readme",
  "bugs": {
    "url": "https://github.com/mate2/svelte-lightslide/issues"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && npm run package",
    "preview": "vite preview",
    "package": "svelte-kit sync && svelte-package && publint",
    "prepublishOnly": "npm run package",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "prepare": "husky"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    }
  },
  "sideEffects": [
    "**/*.css"
  ],
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.5.0",
    "@sveltejs/package": "^2.3.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "husky": "^9.1.7",
    "publint": "^0.2.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0"
  },
  "keywords": [
    "svelte",
    "svelte5",
    "lightbox",
    "gallery",
    "image-gallery",
    "image-viewer",
    "draggable",
    "highslide",
    "slideshow",
    "modal"
  ]
}
